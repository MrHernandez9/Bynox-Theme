<section class="bynox-sticky-cart-wrapper">

  <div class="bynox-container">

    <div class="bynox-sticky-cart-left">

      {% if section.settings.product_image != blank %}
        <img
          src="{{ section.settings.product_image | image_url: width: 200 }}"
          alt="{{ section.settings.title | escape }}"
          width="200"
          height="200"
          loading="lazy"
        >
      {% endif %}

      <div class="bynox-sticky-cart-info">
        <h3>{{ section.settings.title }}</h3>

        <div class="bynox-sticky-cart-price">
          {{ section.settings.price }}
        </div>
      </div>

    </div>

    <div class="bynox-sticky-cart-right">

      <a
        href="{{ section.settings.button_link }}"
        class="bynox-btn bynox-btn-primary"
      >
        {{ section.settings.button_label }}
      </a>

    </div>

  </div>

</section>

<style>
.bynox-sticky-cart-wrapper {
  position: fixed !important;
  bottom: 20px !important;
  left: 0 !important;
  width: 100% !important;
  z-index: 999 !important;

  pointer-events: none !important;
}

.bynox-sticky-cart {
  max-width: 1200px !important;

  margin: 0 auto !important;

  padding: 16px 22px !important;

  border-radius: 24px !important;

  background:
    rgba(11,11,15,.82) !important;

  backdrop-filter: blur(18px) !important;

  border: 1px solid rgba(255,255,255,.08) !important;

  box-shadow:
    0 20px 60px rgba(0,0,0,.45),
    0 0 40px rgba(0,212,255,.08) !important;

  display: flex !important;
  justify-content: space-between !important;
  align-items: center !important;
  gap: 20px !important;

  pointer-events: auto !important;
}

.bynox-sticky-cart-left {
  display: flex !important;
  align-items: center !important;
  gap: 18px !important;
}

.bynox-sticky-cart-left img {
  width: 72px !important;
  height: 72px !important;
  object-fit: cover !important;
  border-radius: 18px !important;

  background: rgba(255,255,255,.04) !important;
}

.bynox-sticky-cart-info h3 {
  margin: 0 0 8px !important;
  color: var(--bynox-white) !important;
  font-size: 18px !important;
}

.bynox-sticky-cart-price {
  color: var(--bynox-cyan) !important;
  font-size: 22px !important;
  font-weight: 800 !important;
}

@media(max-width: 768px) {

  .bynox-sticky-cart-wrapper {
    bottom: 12px !important;
    padding: 0 12px !important;
  }

  .bynox-sticky-cart {
    padding: 14px !important;
    border-radius: 20px !important;
  }

  .bynox-sticky-cart-left img {
    width: 58px !important;
    height: 58px !important;
  }

  .bynox-sticky-cart-info h3 {
    font-size: 15px !important;
  }

  .bynox-sticky-cart-price {
    font-size: 18px !important;
  }

  .bynox-sticky-cart .bynox-btn {
    padding: 14px 18px !important;
    font-size: 14px !important;
  }

}
</style>

{% schema %}
{
  "name": "BYNOX Sticky Cart",
  "settings": [
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Imagen producto"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Corrector de postura BYNOX"
    },
    {
      "type": "text",
      "id": "price",
      "label": "Precio",
      "default": "$39.99"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texto botón",
      "default": "Comprar ahora"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Link botón"
    }
  ],
  "presets": [
    {
      "name": "BYNOX Sticky Cart"
    }
  ]
}
{% endschema %}