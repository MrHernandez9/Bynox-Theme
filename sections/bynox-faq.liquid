<section class="bynox-section bynox-faq-section">
  <div class="bynox-container" data-bynox-reveal>
    <div class="bynox-faq-grid">
      <div class="bynox-faq-content">
        <span>{{ section.settings.badge }}</span>
        <h2>{{ section.settings.heading }}</h2>
        <p>{{ section.settings.subtitle }}</p>
      </div>

      <div class="bynox-faq-list">
        {% for block in section.blocks %}
          <details class="bynox-faq-item" {{ block.shopify_attributes }}>
            <summary>
              {{ block.settings.question }}
              <span>+</span>
            </summary>
            <div class="bynox-faq-answer">
              {{ block.settings.answer }}
            </div>
          </details>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<style>
.bynox-faq-section {
  padding: 120px 0 !important;
}

.bynox-faq-grid {
  display: grid !important;
  grid-template-columns: .8fr 1.2fr !important;
  gap: 70px !important;
  align-items: start !important;
}

.bynox-faq-content span {
  display: inline-flex !important;
  padding: 10px 18px !important;
  border-radius: 999px !important;
  border: 1px solid rgba(0,212,255,.22) !important;
  background: rgba(0,212,255,.08) !important;
  color: var(--bynox-cyan) !important;
  font-weight: 700 !important;
  margin-bottom: 24px !important;
}

.bynox-faq-content h2 {
  font-size: clamp(42px,4vw,68px) !important;
  line-height: 1 !important;
  color: var(--bynox-white) !important;
  margin-bottom: 24px !important;
}

.bynox-faq-content p {
  color: rgba(245,247,250,.72) !important;
  font-size: 20px !important;
  line-height: 1.7 !important;
}

.bynox-faq-list {
  display: flex !important;
  flex-direction: column !important;
  gap: 16px !important;
}

.bynox-faq-item {
  border-radius: 24px !important;
  border: 1px solid rgba(255,255,255,.08) !important;
  background: linear-gradient(180deg, rgba(255,255,255,.06), rgba(255,255,255,.03)) !important;
  overflow: hidden !important;
}

.bynox-faq-item summary {
  cursor: pointer !important;
  list-style: none !important;
  padding: 24px 28px !important;
  display: flex !important;
  justify-content: space-between !important;
  align-items: center !important;
  gap: 20px !important;
  color: var(--bynox-white) !important;
  font-size: 19px !important;
  font-weight: 800 !important;
}

.bynox-faq-item summary::-webkit-details-marker {
  display: none !important;
}

.bynox-faq-item summary span {
  width: 34px !important;
  height: 34px !important;
  border-radius: 999px !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  color: var(--bynox-cyan) !important;
  border: 1px solid rgba(0,212,255,.22) !important;
  flex-shrink: 0 !important;
}

.bynox-faq-item[open] summary span {
  transform: rotate(45deg) !important;
}

.bynox-faq-answer {
  padding: 0 28px 26px !important;
  color: rgba(245,247,250,.72) !important;
  line-height: 1.8 !important;
  font-size: 16px !important;
}

@media(max-width: 900px) {
  .bynox-faq-grid {
    grid-template-columns: 1fr !important;
    gap: 40px !important;
  }

  .bynox-faq-section {
    padding: 80px 0 !important;
  }

  .bynox-faq-content h2 {
    font-size: 42px !important;
  }
}
</style>

{% schema %}
{
  "name": "BYNOX FAQ",
  "settings": [
    {
      "type": "text",
      "id": "badge",
      "label": "Badge",
      "default": "Preguntas frecuentes"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Todo lo que necesitas saber"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Resolvemos las dudas más comunes antes de comprar tu corrector de postura BYNOX."
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "Pregunta",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Pregunta",
          "default": "¿Puedo usarlo debajo de la ropa?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Respuesta",
          "default": "Sí. Su diseño es ligero y discreto, por lo que puedes usarlo debajo de muchas prendas sin incomodidad."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "BYNOX FAQ",
      "blocks": [
        {
          "type": "faq",
          "settings": {
            "question": "¿Puedo usarlo todos los días?",
            "answer": "Sí. Está diseñado para uso diario moderado. Recomendamos comenzar por periodos cortos e ir aumentando según tu comodidad."
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "¿Sirve para trabajar sentado?",
            "answer": "Sí. Es ideal para oficina, estudio, computadora y actividades donde pasas mucho tiempo sentado."
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "¿Es ajustable?",
            "answer": "Sí. Cuenta con correas ajustables para adaptarse mejor a diferentes tipos de cuerpo."
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "¿Corrige la postura de inmediato?",
            "answer": "Ayuda a recordarte mantener una postura más alineada. Los resultados dependen del uso constante y de tus hábitos diarios."
          }
        }
      ]
    }
  ]
}
{% endschema %}