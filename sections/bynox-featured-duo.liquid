<section class="bynox-fd">
  <div class="bynox-fd-inner">

    {% if section.settings.heading != blank %}
      <div class="bynox-fd-header">
        <h2 class="bynox-fd-heading">{{ section.settings.heading }}</h2>
        {% if section.settings.subheading != blank %}
          <p class="bynox-fd-subheading">{{ section.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="bynox-fd-grid">
      {% for block in section.blocks %}
        {% if block.type == 'product_card' %}
          <div class="bynox-fd-card" {{ block.shopify_attributes }}>

            {% if block.settings.bg_image != blank %}
              <img
                class="bynox-fd-card-bg"
                src="{{ block.settings.bg_image | image_url: width: 1200 }}"
                alt="{{ block.settings.title | escape }}"
                width="1200"
                height="800"
                loading="lazy"
              >
            {% else %}
              <div class="bynox-fd-card-bg bynox-fd-bg-placeholder"></div>
            {% endif %}

            <div class="bynox-fd-card-overlay"></div>

            {% if block.settings.sale_price != blank %}
              <div class="bynox-fd-price-badge">
                {% if block.settings.badge_label != blank %}
                  <span class="bynox-fd-badge-sale-label">{{ block.settings.badge_label }}</span>
                  <span class="bynox-fd-badge-sep">|</span>
                {% endif %}
                <span class="bynox-fd-badge-sale-price">{{ block.settings.sale_price }}</span>
                {% if block.settings.original_price != blank %}
                  <span class="bynox-fd-badge-orig-price">{{ block.settings.original_price }}</span>
                {% endif %}
              </div>
            {% endif %}

            <div class="bynox-fd-card-content">
              {% if block.settings.title != blank %}
                <h3 class="bynox-fd-card-title">{{ block.settings.title }}</h3>
              {% endif %}
              {% if block.settings.description != blank %}
                <p class="bynox-fd-card-desc">{{ block.settings.description }}</p>
              {% endif %}
              {% if block.settings.cta_label != blank %}
                <a href="{{ block.settings.cta_url }}" class="bynox-fd-card-btn">
                  {{ block.settings.cta_label }}
                </a>
              {% endif %}
            </div>

          </div>
        {% endif %}
      {% endfor %}
    </div>

  </div>
</section>

<style>
.bynox-fd {
  background: {{ section.settings.bg_color }} !important;
  padding: 72px 0 !important;
  font-family: var(--font-body--family, sans-serif) !important;
}

.bynox-fd-inner {
  max-width: 1320px !important;
  margin: 0 auto !important;
  padding: 0 40px !important;
}

.bynox-fd-header {
  margin-bottom: 32px !important;
}

.bynox-fd-heading {
  font-size: clamp(26px, 3vw, 42px) !important;
  font-weight: 800 !important;
  color: #1a1a1a !important;
  margin: 0 0 10px !important;
}

.bynox-fd-subheading {
  color: #6b6b6b !important;
  font-size: 16px !important;
  line-height: 1.6 !important;
  margin: 0 !important;
  max-width: 640px !important;
}

/* Grid */
.bynox-fd-grid {
  display: grid !important;
  grid-template-columns: 1fr 1fr !important;
  gap: 16px !important;
}

/* Card */
.bynox-fd-card {
  position: relative !important;
  border-radius: 20px !important;
  overflow: hidden !important;
  min-height: 480px !important;
  display: flex !important;
  align-items: flex-end !important;
}

.bynox-fd-card-bg {
  position: absolute !important;
  inset: 0 !important;
  width: 100% !important;
  height: 100% !important;
  object-fit: cover !important;
  object-position: center top !important;
  transition: transform .4s ease !important;
}

.bynox-fd-card:hover .bynox-fd-card-bg {
  transform: scale(1.04) !important;
}

.bynox-fd-bg-placeholder {
  background: #2a2a2a !important;
}

.bynox-fd-card-overlay {
  position: absolute !important;
  inset: 0 !important;
  background: linear-gradient(
    to top,
    rgba(0,0,0,.75) 0%,
    rgba(0,0,0,.25) 55%,
    rgba(0,0,0,.0) 100%
  ) !important;
}

/* Price badge */
.bynox-fd-price-badge {
  position: absolute !important;
  top: 18px !important;
  left: 18px !important;
  z-index: 2 !important;
  display: inline-flex !important;
  align-items: center !important;
  gap: 6px !important;
  background: rgba(255,255,255,.9) !important;
  backdrop-filter: blur(6px) !important;
  border-radius: 999px !important;
  padding: 7px 14px !important;
}

.bynox-fd-badge-sale-label {
  font-size: 12px !important;
  font-weight: 700 !important;
  color: #c0392b !important;
}

.bynox-fd-badge-sep {
  color: #ccc !important;
  font-size: 12px !important;
}

.bynox-fd-badge-sale-price {
  font-size: 13px !important;
  font-weight: 700 !important;
  color: #c0392b !important;
}

.bynox-fd-badge-orig-price {
  font-size: 12px !important;
  color: #9e9e9e !important;
  text-decoration: line-through !important;
}

/* Content */
.bynox-fd-card-content {
  position: relative !important;
  z-index: 2 !important;
  padding: 32px 32px 36px !important;
  width: 100% !important;
}

.bynox-fd-card-title {
  font-size: clamp(24px, 2.5vw, 38px) !important;
  font-weight: 800 !important;
  color: #fff !important;
  margin: 0 0 10px !important;
  line-height: 1.1 !important;
}

.bynox-fd-card-desc {
  color: rgba(255,255,255,.82) !important;
  font-size: 14px !important;
  line-height: 1.6 !important;
  margin: 0 0 22px !important;
  max-width: 380px !important;
}

.bynox-fd-card-btn {
  display: inline-flex !important;
  align-items: center !important;
  padding: 12px 26px !important;
  border-radius: 999px !important;
  background: #fff !important;
  color: #1a1a1a !important;
  font-size: 14px !important;
  font-weight: 700 !important;
  text-decoration: none !important;
  transition: background .2s ease !important;
}

.bynox-fd-card-btn:hover {
  background: #f0ede7 !important;
}

/* Responsive */
@media(max-width: 768px) {
  .bynox-fd { padding: 48px 0 !important; }
  .bynox-fd-inner { padding: 0 20px !important; }
  .bynox-fd-grid { grid-template-columns: 1fr !important; }
  .bynox-fd-card { min-height: 380px !important; }
}
</style>

{% schema %}
{
  "name": "BYNOX Featured Duo",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#faf8f4"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading (optional)"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Section Subheading (optional)"
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Featured Product Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "bg_image",
          "label": "Background / Lifestyle Image"
        },
        {
          "type": "text",
          "id": "badge_label",
          "label": "Badge Label",
          "default": "Sale",
          "info": "e.g. Sale · Limited · New"
        },
        {
          "type": "text",
          "id": "sale_price",
          "label": "Sale Price",
          "default": "$999.99"
        },
        {
          "type": "text",
          "id": "original_price",
          "label": "Original Price (strikethrough)",
          "default": "$1,149.99"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Product Title",
          "default": "Product Name Pro Plus"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Short Description",
          "default": "Fully wireless, designed for serious recovery — lightweight, foldable and ready wherever you train."
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "Button Label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "cta_url",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "BYNOX Featured Duo",
      "blocks": [
        {
          "type": "product_card",
          "settings": {
            "badge_label": "Sale",
            "sale_price": "$999.99",
            "original_price": "$1,149.99",
            "title": "Product Pro Plus",
            "description": "Fully wireless, designed for serious recovery — lightweight, foldable and ready wherever you train.",
            "cta_label": "Shop Pro Plus"
          }
        },
        {
          "type": "product_card",
          "settings": {
            "badge_label": "Sale",
            "sale_price": "$349.99",
            "original_price": "$429.99",
            "title": "Product Prime Plus",
            "description": "Heated, powerful massage for faster, more effective warm-up and recovery.",
            "cta_label": "Shop Prime Plus"
          }
        }
      ]
    }
  ]
}
{% endschema %}