<section class="bynox-section bynox-benefits-section">
 <div class="bynox-container" data-bynox-reveal>

    <div class="bynox-benefits-heading">
      <span>{{ section.settings.badge }}</span>

      <h2>{{ section.settings.heading }}</h2>

      <p>
        {{ section.settings.subtitle }}
      </p>
    </div>

    <div class="bynox-benefits-grid">

      {% for block in section.blocks %}
        <div class="bynox-benefit-card" {{ block.shopify_attributes }}>

          <div class="bynox-benefit-icon">
            {{ block.settings.icon }}
          </div>

          <h3>{{ block.settings.title }}</h3>

          <p>{{ block.settings.description }}</p>

        </div>
      {% endfor %}

    </div>
  </div>
</section>

<style>
.bynox-benefits-section {
  padding: 120px 0 !important;
  position: relative !important;
}

.bynox-benefits-heading {
  text-align: center !important;
  max-width: 850px !important;
  margin: 0 auto 70px !important;
}

.bynox-benefits-heading span {
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
  padding: 10px 18px !important;
  border-radius: 999px !important;
  border: 1px solid rgba(0,212,255,.22) !important;
  background: rgba(0,212,255,.08) !important;
  color: var(--bynox-cyan) !important;
  font-weight: 700 !important;
  margin-bottom: 24px !important;
}

.bynox-benefits-heading h2 {
  font-size: clamp(42px, 4vw, 68px) !important;
  line-height: 1 !important;
  margin-bottom: 24px !important;
  color: var(--bynox-white) !important;
}

.bynox-benefits-heading p {
  color: rgba(245,247,250,.72) !important;
  font-size: 20px !important;
  line-height: 1.7 !important;
}

.bynox-benefits-grid {
  display: grid !important;
  grid-template-columns: repeat(4, minmax(0,1fr)) !important;
  gap: 24px !important;
}

.bynox-benefit-card {
  position: relative !important;
  overflow: hidden !important;
  padding: 34px !important;
  border-radius: 30px !important;
  background:
    linear-gradient(
      180deg,
      rgba(255,255,255,.06),
      rgba(255,255,255,.03)
    ) !important;

  border: 1px solid rgba(255,255,255,.08) !important;

  backdrop-filter: blur(14px) !important;

  transition:
    transform .35s ease,
    border-color .35s ease,
    box-shadow .35s ease !important;
}

.bynox-benefit-card::before {
  content: '' !important;
  position: absolute !important;
  inset: 0 !important;

  background:
    radial-gradient(
      circle at top left,
      rgba(0,212,255,.16),
      transparent 40%
    ) !important;

  opacity: 0 !important;
  transition: opacity .35s ease !important;
}

.bynox-benefit-card:hover {
  transform: translateY(-10px) !important;

  border-color: rgba(0,212,255,.22) !important;

  box-shadow:
    0 30px 60px rgba(0,0,0,.35),
    0 0 40px rgba(0,212,255,.08) !important;
}

.bynox-benefit-card:hover::before {
  opacity: 1 !important;
}

.bynox-benefit-icon {
  width: 72px !important;
  height: 72px !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  border-radius: 22px !important;

  background:
    linear-gradient(
      135deg,
      rgba(37,99,235,.22),
      rgba(0,212,255,.18)
    ) !important;

  border: 1px solid rgba(255,255,255,.08) !important;

  font-size: 34px !important;

  margin-bottom: 26px !important;
}

.bynox-benefit-card h3 {
  font-size: 28px !important;
  line-height: 1.1 !important;
  margin-bottom: 18px !important;
  color: var(--bynox-white) !important;
}

.bynox-benefit-card p {
  color: rgba(245,247,250,.72) !important;
  line-height: 1.8 !important;
  font-size: 16px !important;
}

@media(max-width: 1100px) {

  .bynox-benefits-grid {
    grid-template-columns: repeat(2, minmax(0,1fr)) !important;
  }

}

@media(max-width: 768px) {

  .bynox-benefits-section {
    padding: 80px 0 !important;
  }

  .bynox-benefits-grid {
    grid-template-columns: 1fr !important;
  }

  .bynox-benefits-heading h2 {
    font-size: 42px !important;
  }

}
</style>

{% schema %}
{
  "name": "BYNOX Benefits Grid",
  "settings": [
    {
      "type": "text",
      "id": "badge",
      "label": "Badge",
      "default": "Beneficios"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Diseñado para mejorar tu bienestar diario"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Nuestro corrector de postura combina comodidad, soporte y diseño moderno para ayudarte a sentirte mejor cada día."
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Beneficio",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Ícono",
          "default": "✓"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "Mejora tu postura"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Descripción",
          "default": "Ayuda a mantener una postura más cómoda y alineada durante el día."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "BYNOX Benefits Grid",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "icon": "🧍",
            "title": "Postura Correcta",
            "description": "Ayuda a mantener tu espalda alineada y cómoda."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "💨",
            "title": "Material Transpirable",
            "description": "Diseñado para uso prolongado sin incomodidad."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "⚡",
            "title": "Uso Diario",
            "description": "Perfecto para oficina, estudio o actividades diarias."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "🛡️",
            "title": "Soporte Cómodo",
            "description": "Ajuste seguro y ergonómico para mayor comodidad."
          }
        }
      ]
    }
  ]
}
{% endschema %}