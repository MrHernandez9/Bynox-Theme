        {
          "type": "text",
          "id": "text",
          "label": "Texto",
          "default": "Ayuda a reducir la mala postura"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "BYNOX Hero Producto",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "icon": "✓",
            "text": "Soporte cómodo y ajustable"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "✓",
            "text": "Ideal para trabajo y estudio"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "✓",
            "text": "Diseño ligero y transpirable"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "✓",
            "text": "Mejora tu postura diaria"
          }
        }
      ]
    }
  ]
}
{% endschema %}