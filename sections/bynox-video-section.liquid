<section class="bynox-section bynox-video-section">
  <div class="bynox-container" data-bynox-reveal>
    <div class="bynox-video-grid">
      <div class="bynox-video-content">
        <span>{{ section.settings.badge }}</span>
        <h2>{{ section.settings.heading }}</h2>
        <p>{{ section.settings.subtitle }}</p>

        {% if section.settings.button_label != blank %}
          <a href="{{ section.settings.button_link }}" class="bynox-btn bynox-btn-primary">
            {{ section.settings.button_label }}
          </a>
        {% endif %}
      </div>

      <div class="bynox-video-card">
        {% if section.settings.video_url != blank %}
          {{ section.settings.video_url | video_tag: autoplay: true, loop: true, muted: true, controls: true, image_size: '1200x' }}
        {% elsif section.settings.cover_image != blank %}
          <img
            src="{{ section.settings.cover_image | image_url: width: 1200 }}"
            alt="{{ section.settings.heading | escape }}"
            width="1200"
            height="800"
            loading="lazy"
          >
        {% else %}
          <div class="bynox-video-placeholder">
            Video o imagen del producto
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
.bynox-video-section {
  padding: 120px 0 !important;
}

.bynox-video-grid {
  display: grid !important;
  grid-template-columns: .8fr 1.2fr !important;
  gap: 70px !important;
  align-items: center !important;
}

.bynox-video-content span {
  display: inline-flex !important;
  padding: 10px 18px !important;
  border-radius: 999px !important;
  border: 1px solid rgba(0,212,255,.22) !important;
  background: rgba(0,212,255,.08) !important;
  color: var(--bynox-cyan) !important;
  font-weight: 700 !important;
  margin-bottom: 24px !important;
}

.bynox-video-content h2 {
  font-size: clamp(42px,4vw,68px) !important;
  line-height: 1 !important;
  color: var(--bynox-white) !important;
  margin-bottom: 24px !important;
}

.bynox-video-content p {
  color: rgba(245,247,250,.72) !important;
  font-size: 20px !important;
  line-height: 1.7 !important;
  margin-bottom: 32px !important;
}

.bynox-video-card {
  position: relative !important;
  overflow: hidden !important;
  border-radius: 36px !important;
  min-height: 560px !important;
  background: linear-gradient(180deg, rgba(255,255,255,.06), rgba(255,255,255,.03)) !important;
  border: 1px solid rgba(255,255,255,.08) !important;
  box-shadow: 0 30px 70px rgba(0,0,0,.35) !important;
}

.bynox-video-card::before {
  content: '' !important;
  position: absolute !important;
  inset: auto auto -120px -120px !important;
  width: 320px !important;
  height: 320px !important;
  border-radius: 999px !important;
  background: rgba(0,212,255,.14) !important;
  filter: blur(80px) !important;
  z-index: 1 !important;
}

.bynox-video-card video,
.bynox-video-card img,
.bynox-video-card iframe {
  position: relative !important;
  z-index: 2 !important;
  width: 100% !important;
  height: 100% !important;
  min-height: 560px !important;
  object-fit: cover !important;
  display: block !important;
}

.bynox-video-placeholder {
  min-height: 560px !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  color: var(--bynox-gray) !important;
  font-weight: 800 !important;
}

@media(max-width: 900px) {
  .bynox-video-section {
    padding: 80px 0 !important;
  }

  .bynox-video-grid {
    grid-template-columns: 1fr !important;
    gap: 40px !important;
  }

  .bynox-video-content h2 {
    font-size: 42px !important;
  }

  .bynox-video-card,
  .bynox-video-card video,
  .bynox-video-card img,
  .bynox-video-card iframe,
  .bynox-video-placeholder {
    min-height: 380px !important;
  }
}
</style>

{% schema %}
{
  "name": "BYNOX Video Section",
  "settings": [
    {
      "type": "text",
      "id": "badge",
      "label": "Badge",
      "default": "Míralo en acción"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Comodidad y soporte en cada movimiento"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Muestra el corrector de postura BYNOX en uso para transmitir confianza, comodidad y diseño."
    },
    {
      "type": "video",
      "id": "video_url",
      "label": "Video Shopify"
    },
    {
      "type": "image_picker",
      "id": "cover_image",
      "label": "Imagen alternativa"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texto botón",
      "default": "Comprar ahora"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Link botón"
    }
  ],
  "presets": [
    {
      "name": "BYNOX Video Section"
    }
  ]
}
{% endschema %}