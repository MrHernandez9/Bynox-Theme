<!-- ===== SCRIPTS ===== -->
<script>
(function () {

  /* ----- Thumbnail switcher ----- */
  var mainImg = document.getElementById('bynoxPppMainImg');
  var thumbs  = document.querySelectorAll('.bynox-ppp-thumb');

  thumbs.forEach(function (thumb) {
    thumb.addEventListener('click', function () {
      var src = thumb.dataset.img;
      if (!mainImg || !src) return;
      mainImg.style.opacity = '0';
      mainImg.style.transform = 'scale(.97)';
      setTimeout(function () {
        mainImg.src = src;
        mainImg.style.opacity = '1';
        mainImg.style.transform = 'scale(1)';
      }, 200);
      thumbs.forEach(function (t) { t.classList.remove('active'); });
      thumb.classList.add('active');
    });
  });

  /* ----- Variant option picker ----- */
  var optBtns = document.querySelectorAll('.bynox-ppp-opt-btn');
  var variantInput = document.getElementById('bynoxPppVariantId');
  var variants = {{ product.variants | json }};
  var selectedOptions = {};

  // seed with current selection
  {% for option in product.options_with_values %}
    selectedOptions[{{ option.position }}] = {{ option.selected_value | json }};
  {% endfor %}

  function findVariant() {
    return variants.find(function (v) {
      return v.options.every(function (val, idx) {
        return selectedOptions[idx + 1] === val;
      });
    });
  }

  optBtns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      var pos = parseInt(btn.dataset.optionPos, 10);
      var val = btn.dataset.value;
      selectedOptions[pos] = val;

      // update active state within group
      document.querySelectorAll('[data-option-pos="' + pos + '"]').forEach(function (b) {
        b.classList.remove('active');
      });
      btn.classList.add('active');

      // update selected label
      var lbl = document.getElementById('bynoxSelected' + pos);
      if (lbl) lbl.textContent = val;

      // update hidden variant id
      var matched = findVariant();
      if (matched && variantInput) {
        variantInput.value = matched.id;
      }

      // swap image if variant has one
      if (matched && matched.featured_image && mainImg) {
        mainImg.style.opacity = '0';
        mainImg.style.transform = 'scale(.97)';
        setTimeout(function () {
          mainImg.src = matched.featured_image.src;
          mainImg.style.opacity = '1';
          mainImg.style.transform = 'scale(1)';
        }, 200);
      }
    });
  });

  /* ----- AJAX Add-to-Cart ----- */
  var form = document.getElementById('bynoxPppForm');
  var buyBtn = document.getElementById('bynoxPppBuyBtn');

  if (form) {
    form.addEventListener('submit', function (e) {
      e.preventDefault();
      if (buyBtn) {
        buyBtn.textContent = 'Agregando...';
        buyBtn.style.opacity = '.7';
      }
      fetch('/cart/add.js', {
        method: 'POST',
        body: new FormData(form)
      })
      .then(function (r) { return r.json(); })
      .then(function () {
        return fetch('/cart.js');
      })
      .then(function (r) { return r.json(); })
      .then(function (cart) {
        if (buyBtn) {
          buyBtn.textContent = '{{ section.settings.buy_button_text | default: "Comprar ahora" | escape }}';
          buyBtn.style.opacity = '1';
        }
        // open cart drawer if it exists in the theme
        var drawer = document.getElementById('bynoxCartDrawer');
        if (drawer) {
          var itemsWrap = drawer.querySelector('.bynox-cart-items');
          var totalWrap = drawer.querySelector('.bynox-cart-total-price');
          if (itemsWrap) {
            itemsWrap.innerHTML = cart.items.map(function (item) {
              return '<div class="bynox-cart-item"><img src="' + item.image + '" alt="' + item.product_title + '"><div class="bynox-cart-item-info"><h4>' + item.product_title + '</h4><p>$' + (item.final_line_price / 100).toFixed(2) + '</p></div></div>';
            }).join('');
          }
          if (totalWrap) {
            totalWrap.innerHTML = '$' + (cart.total_price / 100).toFixed(2);
          }
          drawer.classList.add('active');
        }
      })
      .catch(function () {
        if (buyBtn) {
          buyBtn.textContent = '{{ section.settings.buy_button_text | default: "Comprar ahora" | escape }}';
          buyBtn.style.opacity = '1';
        }
      });
    });
  }

})();
</script>

