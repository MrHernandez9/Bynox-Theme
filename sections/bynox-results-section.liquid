<section class="bynox-section bynox-results-section">
  <div class="bynox-container">

    <div class="bynox-results-heading">
      <span>{{ section.settings.badge }}</span>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.subtitle }}</p>
    </div>

    <div class="bynox-results-grid">

      <div class="bynox-result-card">

        <div class="bynox-result-label before">
          {{ section.settings.before_label }}
        </div>

        {% if section.settings.before_image != blank %}
          <img
            src="{{ section.settings.before_image | image_url: width: 1200 }}"
            alt="Antes"
            width="1200"
            height="1200"
            loading="lazy"
          >
        {% else %}
          <div class="bynox-result-placeholder">
            Imagen Antes
          </div>
        {% endif %}

      </div>

      <div class="bynox-result-card">

        <div class="bynox-result-label after">
          {{ section.settings.after_label }}
        </div>

        {% if section.settings.after_image != blank %}
          <img
            src="{{ section.settings.after_image | image_url: width: 1200 }}"
            alt="Después"
            width="1200"
            height="1200"
            loading="lazy"
          >
        {% else %}
          <div class="bynox-result-placeholder">
            Imagen Después
          </div>
        {% endif %}

      </div>

    </div>

  </div>
</section>

<style>
.bynox-results-section {
  padding: 120px 0 !important;
}

.bynox-results-heading {
  text-align: center !important;
  max-width: 850px !important;
  margin: 0 auto 70px !important;
}

.bynox-results-heading span {
  display: inline-flex !important;
  padding: 10px 18px !important;
  border-radius: 999px !important;
  border: 1px solid rgba(0,212,255,.22) !important;
  background: rgba(0,212,255,.08) !important;
  color: var(--bynox-cyan) !important;
  font-weight: 700 !important;
  margin-bottom: 24px !important;
}

.bynox-results-heading h2 {
  font-size: clamp(42px,4vw,68px) !important;
  line-height: 1 !important;
  color: var(--bynox-white) !important;
  margin-bottom: 24px !important;
}

.bynox-results-heading p {
  color: rgba(245,247,250,.72) !important;
  font-size: 20px !important;
  line-height: 1.7 !important;
}

.bynox-results-grid {
  display: grid !important;
  grid-template-columns: repeat(2, minmax(0,1fr)) !important;
  gap: 28px !important;
}

.bynox-result-card {
  position: relative !important;
  overflow: hidden !important;

  border-radius: 34px !important;

  background:
    linear-gradient(
      180deg,
      rgba(255,255,255,.06),
      rgba(255,255,255,.03)
    ) !important;

  border: 1px solid rgba(255,255,255,.08) !important;

  min-height: 680px !important;

  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
}

.bynox-result-card img {
  width: 100% !important;
  height: 100% !important;
  object-fit: cover !important;

  transition: transform .4s ease !important;
}

.bynox-result-card:hover img {
  transform: scale(1.04) !important;
}

.bynox-result-label {
  position: absolute !important;
  top: 24px !important;
  left: 24px !important;
  z-index: 5 !important;

  padding: 12px 18px !important;

  border-radius: 999px !important;

  font-weight: 800 !important;

  color: #fff !important;

  backdrop-filter: blur(10px) !important;
}

.bynox-result-label.before {
  background: rgba(255,90,90,.78) !important;
}

.bynox-result-label.after {
  background: rgba(0,212,255,.78) !important;
}

.bynox-result-placeholder {
  color: var(--bynox-gray) !important;
  font-weight: 700 !important;
}

@media(max-width: 900px) {

  .bynox-results-grid {
    grid-template-columns: 1fr !important;
  }

  .bynox-results-section {
    padding: 80px 0 !important;
  }

  .bynox-results-heading h2 {
    font-size: 42px !important;
  }

  .bynox-result-card {
    min-height: 420px !important;
  }

}
</style>

{% schema %}
{
  "name": "BYNOX Results Section",
  "settings": [
    {
      "type": "text",
      "id": "badge",
      "label": "Badge",
      "default": "Resultados"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Siente la diferencia en tu postura"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "BYNOX está diseñado para ayudarte a mantener una postura más cómoda y alineada en tu rutina diaria."
    },
    {
      "type": "text",
      "id": "before_label",
      "label": "Etiqueta antes",
      "default": "Antes"
    },
    {
      "type": "text",
      "id": "after_label",
      "label": "Etiqueta después",
      "default": "Después"
    },
    {
      "type": "image_picker",
      "id": "before_image",
      "label": "Imagen antes"
    },
    {
      "type": "image_picker",
      "id": "after_image",
      "label": "Imagen después"
    }
  ],
  "presets": [
    {
      "name": "BYNOX Results Section"
    }
  ]
}
{% endschema %}