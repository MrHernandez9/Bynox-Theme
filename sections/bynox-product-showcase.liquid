  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Ícono",
          "default": "✓"
        },
        {
          "type": "text",
          "id": "title",
         "label": "Título"
         },
        {
          "type": "textarea",
          "id": "text",
          "label": "Texto"
        }
      ]
    },
    {
      "type": "image",
      "name": "Imagen secundaria",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "BYNOX Product Showcase",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "🧍",
            "title": "Mejora tu postura",
            "text": "Ayuda a mantener una posición más cómoda y alineada."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "💨",
            "title": "Diseño transpirable",
            "text": "Material cómodo para usar durante horas."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "⚡",
            "title": "Uso diario",
            "text": "Perfecto para oficina, estudio y trabajo."
          }
        }
      ]
    }
  ]
}
{% endschema %}