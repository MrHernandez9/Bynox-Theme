<section class="bynox-section bynox-comparison-section">
  <div class="bynox-container">
    <div class="bynox-comparison-heading">
      <span>{{ section.settings.badge }}</span>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.subtitle }}</p>
    </div>

    <div class="bynox-comparison-table">
      <div class="bynox-comparison-row bynox-comparison-head">
        <div>Características</div>
        <div>BYNOX</div>
        <div>Genérico</div>
      </div>

      {% for block in section.blocks %}
        <div class="bynox-comparison-row" {{ block.shopify_attributes }}>
          <div>{{ block.settings.feature }}</div>
          <div class="good">{{ block.settings.bynox_value }}</div>
          <div class="bad">{{ block.settings.generic_value }}</div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
.bynox-comparison-section {
  padding: 120px 0 !important;
}

.bynox-comparison-heading {
  text-align: center !important;
  max-width: 850px !important;
  margin: 0 auto 70px !important;
}

.bynox-comparison-heading span {
  display: inline-flex !important;
  padding: 10px 18px !important;
  border-radius: 999px !important;
  border: 1px solid rgba(0,212,255,.22) !important;
  background: rgba(0,212,255,.08) !important;
  color: var(--bynox-cyan) !important;
  font-weight: 700 !important;
  margin-bottom: 24px !important;
}

.bynox-comparison-heading h2 {
  font-size: clamp(42px,4vw,68px) !important;
  line-height: 1 !important;
  color: var(--bynox-white) !important;
  margin-bottom: 24px !important;
}

.bynox-comparison-heading p {
  color: rgba(245,247,250,.72) !important;
  font-size: 20px !important;
  line-height: 1.7 !important;
}

.bynox-comparison-table {
  overflow: hidden !important;
  border-radius: 32px !important;
  border: 1px solid rgba(255,255,255,.08) !important;
  background: linear-gradient(180deg, rgba(255,255,255,.06), rgba(255,255,255,.03)) !important;
}

.bynox-comparison-row {
  display: grid !important;
  grid-template-columns: 1.2fr .7fr .7fr !important;
  border-bottom: 1px solid rgba(255,255,255,.08) !important;
}

.bynox-comparison-row:last-child {
  border-bottom: none !important;
}

.bynox-comparison-row > div {
  padding: 26px 28px !important;
  color: rgba(245,247,250,.78) !important;
  font-weight: 700 !important;
}

.bynox-comparison-row > div:not(:last-child) {
  border-right: 1px solid rgba(255,255,255,.08) !important;
}

.bynox-comparison-head {
  background: rgba(0,212,255,.08) !important;
}

.bynox-comparison-head > div {
  color: var(--bynox-white) !important;
  font-size: 18px !important;
}

.bynox-comparison-row .good {
  color: #76F7B2 !important;
}

.bynox-comparison-row .bad {
  color: rgba(245,247,250,.45) !important;
}

@media(max-width: 768px) {
  .bynox-comparison-section {
    padding: 80px 0 !important;
  }

  .bynox-comparison-row {
    grid-template-columns: 1fr !important;
  }

  .bynox-comparison-row > div {
    border-right: none !important;
    border-bottom: 1px solid rgba(255,255,255,.06) !important;
  }

  .bynox-comparison-heading h2 {
    font-size: 42px !important;
  }
}
</style>

{% schema %}
{
  "name": "BYNOX Comparison Table",
  "settings": [
    {
      "type": "text",
      "id": "badge",
      "label": "Badge",
      "default": "Comparación"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "No todos los correctores son iguales"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "BYNOX está pensado para ofrecer una experiencia más cómoda, moderna y confiable."
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Fila",
      "settings": [
        {
          "type": "text",
          "id": "feature",
          "label": "Característica",
          "default": "Diseño ajustable"
        },
        {
          "type": "text",
          "id": "bynox_value",
          "label": "Valor BYNOX",
          "default": "✓ Sí"
        },
        {
          "type": "text",
          "id": "generic_value",
          "label": "Valor genérico",
          "default": "Limitado"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "BYNOX Comparison Table",
      "blocks": [
        {
          "type": "row",
          "settings": {
            "feature": "Diseño ajustable",
            "bynox_value": "✓ Sí",
            "generic_value": "Limitado"
          }
        },
        {
          "type": "row",
          "settings": {
            "feature": "Material transpirable",
            "bynox_value": "✓ Sí",
            "generic_value": "No siempre"
          }
        },
        {
          "type": "row",
          "settings": {
            "feature": "Uso diario cómodo",
            "bynox_value": "✓ Optimizado",
            "generic_value": "Puede molestar"
          }
        },
        {
          "type": "row",
          "settings": {
            "feature": "Estilo discreto",
            "bynox_value": "✓ Minimalista",
            "generic_value": "Voluminoso"
          }
        }
      ]
    }
  ]
}
{% endschema %}