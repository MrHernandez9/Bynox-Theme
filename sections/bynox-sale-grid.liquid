<section class="bynox-sg">
  <div class="bynox-sg-inner">

    <div class="bynox-sg-header">
      {% if section.settings.heading != blank %}
        <h2 class="bynox-sg-heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p class="bynox-sg-subheading">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    {% assign col = collections[section.settings.collection] %}
    {% if col and col.products.size > 0 %}
      <div class="bynox-sg-grid" style="--sg-cols: {{ section.settings.columns }};">
        {% for product in col.products limit: section.settings.max_products %}
          <a href="{{ product.url }}" class="bynox-sg-card">

            <div class="bynox-sg-img-wrap">
              {% if product.compare_at_price > product.price and section.settings.show_sale_badge %}
                <span class="bynox-sg-badge">{{ section.settings.sale_badge_text | default: 'Sale' }}</span>
              {% endif %}
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  alt="{{ product.title | escape }}"
                  width="600"
                  height="600"
                  loading="lazy"
                >
              {% else %}
                <div class="bynox-sg-no-img"></div>
              {% endif %}
            </div>

            <div class="bynox-sg-info">
              <p class="bynox-sg-title">{{ product.title }}</p>
              {% if product.description != blank %}
                <p class="bynox-sg-desc">
                  {{ product.description | strip_html | truncate: 80 }}
                </p>
              {% endif %}
              <div class="bynox-sg-price-row">
                {% if product.compare_at_price > product.price %}
                  <span class="bynox-sg-price-sale">{{ product.price | money }}</span>
                  <span class="bynox-sg-price-orig">{{ product.compare_at_price | money }}</span>
                {% else %}
                  <span class="bynox-sg-price-reg">{{ product.price | money }}</span>
                {% endif %}
              </div>
            </div>

          </a>
        {% endfor %}
      </div>

    {% else %}

      <!-- Placeholder cards (shown when no collection is selected) -->
      <div class="bynox-sg-grid" style="--sg-cols: {{ section.settings.columns }};">
        {% for i in (1..section.settings.columns) %}
          <div class="bynox-sg-card bynox-sg-placeholder">
            <div class="bynox-sg-img-wrap">
              <span class="bynox-sg-badge">{{ section.settings.sale_badge_text | default: 'Sale' }}</span>
              <div class="bynox-sg-no-img"></div>
            </div>
            <div class="bynox-sg-info">
              <p class="bynox-sg-title">Product Name</p>
              <p class="bynox-sg-desc">Short product description goes here.</p>
              <div class="bynox-sg-price-row">
                <span class="bynox-sg-price-sale">$99.00</span>
                <span class="bynox-sg-price-orig">$129.00</span>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>

    {% endif %}

    {% if section.settings.cta_label != blank %}
      <div class="bynox-sg-footer">
        <a href="{{ section.settings.cta_url }}" class="bynox-sg-cta">
          {{ section.settings.cta_label }}
        </a>
      </div>
    {% endif %}

  </div>
</section>

<style>
.bynox-sg {
  background: {{ section.settings.bg_color }} !important;
  padding: 72px 0 !important;
  font-family: var(--font-body--family, sans-serif) !important;
}

.bynox-sg-inner {
  max-width: 1320px !important;
  margin: 0 auto !important;
  padding: 0 40px !important;
}

.bynox-sg-header {
  margin-bottom: 36px !important;
}

.bynox-sg-heading {
  font-size: clamp(26px, 3vw, 42px) !important;
  font-weight: 800 !important;
  color: #1a1a1a !important;
  margin: 0 0 10px !important;
  line-height: 1.1 !important;
}

.bynox-sg-subheading {
  font-size: 16px !important;
  color: #6b6b6b !important;
  margin: 0 !important;
  max-width: 600px !important;
  line-height: 1.6 !important;
}

/* Grid */
.bynox-sg-grid {
  display: grid !important;
  grid-template-columns: repeat(var(--sg-cols, 4), 1fr) !important;
  gap: 16px !important;
}

/* Card */
.bynox-sg-card {
  text-decoration: none !important;
  display: flex !important;
  flex-direction: column !important;
  border-radius: 16px !important;
  overflow: hidden !important;
  background: #fff !important;
  border: 1px solid rgba(0,0,0,.06) !important;
  transition: box-shadow .25s ease, transform .25s ease !important;
}

.bynox-sg-card:hover {
  box-shadow: 0 8px 28px rgba(0,0,0,.1) !important;
  transform: translateY(-4px) !important;
}

/* Image */
.bynox-sg-img-wrap {
  position: relative !important;
  background: #f0ede7 !important;
  aspect-ratio: 1 !important;
  overflow: hidden !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
}

.bynox-sg-img-wrap img {
  width: 80% !important;
  height: 80% !important;
  object-fit: contain !important;
  transition: transform .3s ease !important;
}

.bynox-sg-card:hover .bynox-sg-img-wrap img {
  transform: scale(1.05) !important;
}

.bynox-sg-no-img {
  width: 100% !important;
  height: 100% !important;
  background: #e8e4dc !important;
}

/* Sale badge */
.bynox-sg-badge {
  position: absolute !important;
  top: 12px !important;
  left: 12px !important;
  z-index: 2 !important;
  background: #c0392b !important;
  color: #fff !important;
  font-size: 12px !important;
  font-weight: 700 !important;
  padding: 4px 10px !important;
  border-radius: 999px !important;
  letter-spacing: .02em !important;
}

/* Info */
.bynox-sg-info {
  padding: 16px !important;
  flex: 1 !important;
  display: flex !important;
  flex-direction: column !important;
  gap: 6px !important;
}

.bynox-sg-title {
  font-size: 15px !important;
  font-weight: 700 !important;
  color: #1a1a1a !important;
  margin: 0 !important;
  line-height: 1.35 !important;
}

.bynox-sg-desc {
  font-size: 13px !important;
  color: #6b6b6b !important;
  margin: 0 !important;
  line-height: 1.5 !important;
  flex: 1 !important;
}

.bynox-sg-price-row {
  display: flex !important;
  align-items: center !important;
  gap: 8px !important;
  margin-top: 4px !important;
}

.bynox-sg-price-sale {
  font-size: 15px !important;
  font-weight: 700 !important;
  color: #c0392b !important;
}

.bynox-sg-price-orig {
  font-size: 13px !important;
  color: #9e9e9e !important;
  text-decoration: line-through !important;
}

.bynox-sg-price-reg {
  font-size: 15px !important;
  font-weight: 700 !important;
  color: #1a1a1a !important;
}

/* Footer CTA */
.bynox-sg-footer {
  margin-top: 40px !important;
  text-align: center !important;
}

.bynox-sg-cta {
  display: inline-flex !important;
  padding: 14px 32px !important;
  border-radius: 999px !important;
  background: #1a1a1a !important;
  color: #fff !important;
  font-size: 15px !important;
  font-weight: 700 !important;
  text-decoration: none !important;
  transition: background .2s ease !important;
}

.bynox-sg-cta:hover {
  background: #333 !important;
}

/* Responsive */
@media(max-width: 1100px) {
  .bynox-sg-grid { grid-template-columns: repeat(3, 1fr) !important; }
}
@media(max-width: 768px) {
  .bynox-sg { padding: 48px 0 !important; }
  .bynox-sg-inner { padding: 0 20px !important; }
  .bynox-sg-grid { grid-template-columns: repeat(2, 1fr) !important; }
}
@media(max-width: 440px) {
  .bynox-sg-grid { grid-template-columns: 1fr !important; }
}
</style>

{% schema %}
{
  "name": "BYNOX Sale Grid",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#faf8f4"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Our best savings on gifts they will love"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading (optional)"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Product Collection"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Max Products to Show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns (desktop)",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_sale_badge",
      "label": "Show Sale Badge on Discounted Products",
      "default": true
    },
    {
      "type": "text",
      "id": "sale_badge_text",
      "label": "Sale Badge Label",
      "default": "Sale"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Footer Button Label (optional)"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Footer Button Link"
    }
  ],
  "presets": [
    {
      "name": "BYNOX Sale Grid"
    }
  ]
}
{% endschema %}